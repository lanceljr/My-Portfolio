+
+  <!-- ── Password gate ──────────────────────────────────────── -->
+  <div class="pw-overlay" id="pwOverlay" role="dialog" aria-modal="true" aria-label="Password required">
+    <div class="pw-card-wrap">
+      <div class="pw-card">
+        <h3>🔒 Protected</h3>
+        <p class="pw-hint">It's in the <em>top right</em> of the resume!</p>
+        <div class="pw-input-row">
+          <input class="pw-input" id="pwInput" type="password" placeholder="Enter password" autocomplete="off" />
+          <button class="pw-submit" id="pwSubmit">Enter →</button>
+        </div>
+        <p class="pw-error" id="pwError"></p>
+      </div>
+      <button class="pw-close" id="pwClose" aria-label="Cancel">✕</button>
+    </div>
+  </div>
+
+  <script>
+    (() => {
+      const AUTH_KEY  = 'portfolio_unlocked';
+      // PBKDF2-SHA256 (300 000 iterations) of the gate password.
+      // Raw password is never present in source or devtools.
+      const PW_HASH   = 'c89cf7ea010d27df55fd23a659af41f6014e243b4b41cbf501af5308bb8ac91a';
+      const PW_SALT   = 'lancelim_portfolio_2024';
+      const PW_ITERS  = 300000;
+      const overlay   = document.getElementById('pwOverlay');
+      const input     = document.getElementById('pwInput');
+      const submit    = document.getElementById('pwSubmit');
+      const errorEl   = document.getElementById('pwError');
+      const closeBtn  = document.getElementById('pwClose');
+
+      let pendingHash = null;
+
+      // Check if already unlocked this session
+      const isUnlocked = () => sessionStorage.getItem(AUTH_KEY) === '1';
+
+      // Public entry point used by every click handler. If the user is already
+      // unlocked, route straight through; otherwise hold the slug and prompt.
+      window.requestCase = (slug) => {
+        if (!slug || !slug.startsWith('case-')) return;
+        // Idempotency: if the gate is already showing, ignore. Prevents
+        // double-firing from touchend + click + direct CTA handler.
+        if (overlay.classList.contains('open')) return;
+        if (isUnlocked()) {
+          window.location.hash = slug;
+          return;
+        }
+        pendingHash = slug;
+        openOverlay();
+      };
+
+      // Lock body scroll while the modal is open so the works section
+      // doesn't shift behind the overlay. We freeze the scroll position
+      // with `position: fixed; top: -Y` (the only reliable cross-browser
+      // technique on iOS) and restore it on close.
+      let savedScrollY = 0;
+      function lockScroll() {
+        savedScrollY = window.scrollY || window.pageYOffset || 0;
+        document.body.style.position = 'fixed';
+        document.body.style.top = `-${savedScrollY}px`;
+        document.body.style.left = '0';
+        document.body.style.right = '0';
+        document.body.style.width = '100%';
+      }
+      function unlockScroll() {
+        document.body.style.position = '';
+        document.body.style.top = '';
+        document.body.style.left = '';
+        document.body.style.right = '';
+        document.body.style.width = '';
+        window.scrollTo(0, savedScrollY);
+      }
+
+      function openOverlay() {
+        overlay.classList.add('open');
+        input.value = '';
+        errorEl.textContent = '';
+        input.classList.remove('error');
+        lockScroll();
+        // `preventScroll: true` stops the browser from auto-scrolling the
+        // page so the focused input stays anchored (avoids the perceived
+        // "title moved / background changed" jump on mobile).
+        requestAnimationFrame(() => {
+          try { input.focus({ preventScroll: true }); }
+          catch (e) { input.focus(); }
+        });
+      }
+
+      function closeOverlay() {
+        overlay.classList.remove('open');
+        unlockScroll();
+        pendingHash = null;
+        // Clear any leftover case hash so the URL bar is clean
+        if (window.location.hash.startsWith('#case-')) {
+          history.replaceState(null, '', '#');
+        }
+        // If the user is currently sitting on a case view (direct URL load),
+        // send them back to the home page when they dismiss the gate.
+        const activeView = document.querySelector('.view.active');
+        if (activeView && activeView.dataset.view !== 'home' && typeof showView === 'function') {
+          showView('home');
+        }
+      }
+
+      // Derives a PBKDF2-SHA256 hex string from the candidate password.
+      // 300 000 iterations means brute-forcing the stored hash is
+      // computationally impractical even with the salt visible in source.
+      async function pbkdf2Hex(str) {
+        const enc = new TextEncoder();
+        const keyMaterial = await crypto.subtle.importKey(
+          'raw', enc.encode(str), 'PBKDF2', false, ['deriveBits']
+        );
+        const bits = await crypto.subtle.deriveBits(
+          { name: 'PBKDF2', salt: enc.encode(PW_SALT), iterations: PW_ITERS, hash: 'SHA-256' },
+          keyMaterial,
+          256
+        );
+        return Array.from(new Uint8Array(bits))
+          .map(b => b.toString(16).padStart(2, '0'))
+          .join('');
+      }
+
+      async function attempt() {
+        const candidate = input.value.trim();
+        if (!candidate) return;
+        let hex;
+        try {
+          hex = await pbkdf2Hex(candidate);
+        } catch (err) {
+          errorEl.textContent = 'Browser does not support secure hashing.';
+          input.classList.add('error');
+          return;
+        }
+        if (hex === PW_HASH) {
+          sessionStorage.setItem(AUTH_KEY, '1');
+          overlay.classList.remove('open');
+          unlockScroll();
+          if (pendingHash) {
+            window.location.hash = pendingHash;
+            pendingHash = null;
+          }
+        } else {
+          errorEl.textContent = 'Wrong password — try again.';
+          input.classList.add('error');
+          input.select();
+        }
+      }
+
+      submit.addEventListener('click', attempt);
+      input.addEventListener('keydown', e => { if (e.key === 'Enter') attempt(); });
+      closeBtn.addEventListener('click', closeOverlay);
+      overlay.addEventListener('click', e => { if (e.target === overlay) closeOverlay(); });
+      input.addEventListener('input', () => {
+        input.classList.remove('error');
+        errorEl.textContent = '';
+      });
+
+      // Override openCase by patching the hash-based navigation at the routing level
+      // We intercept hashchange: if not unlocked and hash is a case, show gate.
+      window.addEventListener('hashchange', (e) => {
+        const hash = window.location.hash.slice(1);
+        if (hash.startsWith('case-') && !isUnlocked()) {
+          // Stop the main handleHash listener from running — that would switch
+          // the view to the case study and scroll the page to top. We want the
+          // user to stay exactly where they are (e.g. the works section).
+          e.stopImmediatePropagation();
+          history.replaceState(null, '', '#');
+          pendingHash = hash;
+          openOverlay();
+        }
+      }, true); // capture phase so it fires before the existing listener
+
+      // Browser back / forward should dismiss the modal and return home
+      window.addEventListener('popstate', () => {
+        if (overlay.classList.contains('open')) {
+          closeOverlay();
+        }
+      });
+
+      // Also gate direct hash on load.
+      // Direct URL access ALWAYS prompts — even if the user was unlocked in a
+      // previous tab/session. They must re-authenticate to view the case
+      // study. Closing the X routes them back to home (see closeOverlay).
+      (() => {
+        const hash = window.location.hash.slice(1);
+        if (hash.startsWith('case-')) {
+          sessionStorage.removeItem(AUTH_KEY);
+          pendingHash = hash;
+          openOverlay();
+        }
+      })();
+    })();
+  </script>
+</body>
