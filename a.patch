+    /* ─── Responsive ──────────────────────────────────────── */
+    @media (max-width: 900px) {
+      /* Override the global scroll-snap-stop:always so mobile scrolling
+         uses momentum and doesn't hard-lock at every section boundary. */
+      .hero, .about, .works, .contact { scroll-snap-stop: normal; }
+
