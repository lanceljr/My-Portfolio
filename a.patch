+         shrinking URL bar on mobile Safari/Chrome. */
+      .contact {
+        min-height: 100dvh;
+        display: flex;
+        flex-direction: column;
+        justify-content: center;
+      }
+      .topbar { left: 20px; right: 20px; top: 20px; font-size: 0.62rem; }
