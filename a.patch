+         full viewport with the text vertically centered. */
+      .about { min-height: 260dvh; padding: 0; }
+      .about-sticky {
+        position: sticky;
+        top: 0;
+        height: 100dvh;
+        padding: 0 20px;
+        justify-content: center;
+        max-width: none;
+      }
+      .about-label { margin-bottom: 24px; }
+      .about-text  { font-size: clamp(1.35rem, 5.2vw, 1.7rem); line-height: 1.45; }
